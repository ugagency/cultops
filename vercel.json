{
  "version": 2,
  "builds": [
    { "src": "api/salic/inserir.js", "use": "@vercel/node" },
    { "src": "server.js", "use": "@vercel/node", "config": { "maxDuration": 300 } },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "module-selector.html", "use": "@vercel/static" },
    { "src": "modulo2/**", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.ico", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/salic/inserir", "destination": "/api/salic/inserir.js" },
    { "source": "/", "destination": "/module-selector.html" },
    { "source": "/api/:path*", "destination": "/server.js" },
    { "source": "/config.js", "destination": "/server.js" }
  ]
}
